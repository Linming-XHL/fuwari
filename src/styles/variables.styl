/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.08 20), oklch(0.80 0.08 40), oklch(0.80 0.08 60), oklch(0.80 0.08 80), oklch(0.80 0.08 100), oklch(0.80 0.08 120), oklch(0.80 0.08 140), oklch(0.80 0.08 160), oklch(0.80 0.08 180), oklch(0.80 0.08 200), oklch(0.80 0.08 220), oklch(0.80 0.08 240), oklch(0.80 0.08 260))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.08 20), oklch(0.70 0.08 40), oklch(0.70 0.08 60), oklch(0.70 0.08 80), oklch(0.70 0.08 100), oklch(0.70 0.08 120), oklch(0.70 0.08 140), oklch(0.70 0.08 160), oklch(0.70 0.08 180), oklch(0.70 0.08 200), oklch(0.70 0.08 220), oklch(0.70 0.08 240), oklch(0.70 0.08 260))

:root
  --radius-large 1rem
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: oklch(0.65 0.08 55) oklch(0.70 0.08 55)
  --page-bg: oklch(0.95 0.06 85) oklch(0.16 0.02 55)
  --card-bg: white oklch(0.23 0.015 55)

  --btn-content: oklch(0.55 0.08 55) oklch(0.75 0.06 55)

  --btn-regular-bg: oklch(0.95 0.02 55) oklch(0.33 0.025 55)
  --btn-regular-bg-hover: oklch(0.9 0.04 55) oklch(0.38 0.03 55)
  --btn-regular-bg-active: oklch(0.85 0.06 55) oklch(0.43 0.035 55)

  --btn-plain-bg-hover: oklch(0.95 0.02 55) oklch(0.30 0.025 55)
  --btn-plain-bg-active: oklch(0.98 0.008 55) oklch(0.27 0.02 55)

  --btn-card-bg-hover: oklch(0.98 0.005 55) oklch(0.3 0.02 55)
  --btn-card-bg-active: oklch(0.9 0.02 55) oklch(0.35 0.025 55)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: oklch(0.25 0.02 55)

  --title-active: oklch(0.6 0.08 55)

  --line-divider: black(0.08) white(0.08)

  --line-color: black(0.1) white(0.1)
  --meta-divider: black(0.2) white(0.2)

  --inline-code-bg: var(--btn-regular-bg)
  --inline-code-color: var(--btn-content)
  --selection-bg: oklch(0.90 0.04 85) oklch(0.40 0.06 55)
  --codeblock-selection: oklch(0.40 0.06 55)
  --codeblock-bg: oklch(0.17 0.015 55) oklch(0.17 0.015 55)
  --codeblock-topbar-bg: oklch(0.3 0.02 55) oklch(0.12 0.015 55)

  --license-block-bg: black(0.03) var(--codeblock-bg)

  --link-underline: oklch(0.93 0.04 85) oklch(0.40 0.06 55)
  --link-hover: oklch(0.95 0.025 85) oklch(0.40 0.06 55)
  --link-active: oklch(0.90 0.04 85) oklch(0.35 0.05 55)

  --float-panel-bg: white oklch(0.19 0.015 55)

  --scrollbar-bg-light: black(0.4)
  --scrollbar-bg-hover-light: black(0.5)
  --scrollbar-bg-active-light: black(0.6)

  --scrollbar-bg-dark: white(0.4)
  --scrollbar-bg-hover-dark: white(0.5)
  --scrollbar-bg-active-dark: white(0.6)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: oklch(0.7 0.12 140) oklch(0.75 0.12 140)
  --admonitions-color-note: oklch(0.7 0.10 55) oklch(0.75 0.10 55)
  --admonitions-color-important: oklch(0.7 0.12 310) oklch(0.75 0.12 310)
  --admonitions-color-warning: oklch(0.7 0.12 85) oklch(0.75 0.12 85)
  --admonitions-color-caution: oklch(0.6 0.15 25) oklch(0.65 0.15 25)

  --toc-badge-bg: oklch(0.89 0.04 85) var(--btn-regular-bg)
  --toc-btn-hover: oklch(0.926 0.015 55) oklch(0.22 0.02 55)
  --toc-btn-active: oklch(0.90 0.015 55) oklch(0.25 0.02 55)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.70 0.10 55) oklch(0.35 0.05 55)
})
