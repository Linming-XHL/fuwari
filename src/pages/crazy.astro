---
title: "Crazy Entertainment Page"
description: "An outrageous and visually striking entertainment page with SVG animations and emoji"
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crazy Entertainment</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            overflow: hidden;
            background-color: #000;
            height: 100vh;
            width: 100vw;
        }
        
        .container {
            position: relative;
            width: 100%;
            height: 100%;
        }
        
        svg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }
        
        audio {
            position: absolute;
            bottom: 20px;
            left: 20px;
            z-index: 10;
            opacity: 0.5;
            transition: opacity 0.3s ease;
        }
        
        audio:hover {
            opacity: 1;
        }
        
        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, rgba(0,0,0,0) 0%, rgba(0,0,0,0.8) 100%);
            z-index: 2;
            pointer-events: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- SVG Animation -->
        <svg viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg">
            <!-- Background Animation -->
            <rect width="1000" height="1000" fill="none">
                <animate attributeName="fill" values="#000;#ff00ff;#00ffff;#ffff00;#ff0000;#000" dur="10s" repeatCount="indefinite" />
            </rect>
            
            <!-- Abstract Shapes -->
            <circle cx="500" cy="500" r="400" fill="none" stroke="#fff" stroke-width="2">
                <animate attributeName="r" values="400;300;500;400" dur="8s" repeatCount="indefinite" />
                <animate attributeName="stroke-width" values="2;5;2" dur="4s" repeatCount="indefinite" />
                <animate attributeName="stroke" values="#fff;#ff0000;#fff" dur="6s" repeatCount="indefinite" />
            </circle>
            
            <rect x="250" y="250" width="500" height="500" fill="none" stroke="#fff" stroke-width="2" transform="rotate(45 500 500)">
                <animate attributeName="width" values="500;400;600;500" dur="7s" repeatCount="indefinite" />
                <animate attributeName="height" values="500;600;400;500" dur="9s" repeatCount="indefinite" />
                <animate attributeName="stroke" values="#fff;#00ff00;#fff" dur="5s" repeatCount="indefinite" />
            </rect>
            
            <!-- Emoji Elements -->
            <!-- 😱 -->
            <text x="100" y="100" font-size="50" fill="#fff">
                😱
                <animate attributeName="x" values="100;200;100" dur="4s" repeatCount="indefinite" />
                <animate attributeName="y" values="100;150;100" dur="3s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="50;80;50" dur="5s" repeatCount="indefinite" />
            </text>
            
            <!-- 🎉 -->
            <text x="900" y="100" font-size="60" fill="#fff">
                🎉
                <animate attributeName="x" values="900;800;900" dur="5s" repeatCount="indefinite" />
                <animate attributeName="y" values="100;200;100" dur="4s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="60;90;60" dur="6s" repeatCount="indefinite" />
            </text>
            
            <!-- 👾 -->
            <text x="500" y="200" font-size="70" fill="#fff">
                👾
                <animate attributeName="x" values="500;400;600;500" dur="8s" repeatCount="indefinite" />
                <animate attributeName="y" values="200;150;250;200" dur="7s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="70;100;70" dur="9s" repeatCount="indefinite" />
            </text>
            
            <!-- 🚀 -->
            <text x="100" y="900" font-size="60" fill="#fff">
                🚀
                <animate attributeName="x" values="100;900;100" dur="10s" repeatCount="indefinite" />
                <animate attributeName="y" values="900;100;900" dur="8s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="60;80;60" dur="5s" repeatCount="indefinite" />
            </text>
            
            <!-- 🔥 -->
            <text x="900" y="900" font-size="50" fill="#fff">
                🔥
                <animate attributeName="x" values="900;800;900" dur="4s" repeatCount="indefinite" />
                <animate attributeName="y" values="900;850;900" dur="3s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="50;70;50" dur="6s" repeatCount="indefinite" />
            </text>
            
            <!-- 💀 -->
            <text x="500" y="500" font-size="100" fill="#fff">
                💀
                <animate attributeName="transform" values="rotate(0 500 500);rotate(360 500 500)" dur="10s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="100;120;100" dur="7s" repeatCount="indefinite" />
            </text>
            
            <!-- 🌈 -->
            <text x="300" y="700" font-size="60" fill="#fff">
                🌈
                <animate attributeName="x" values="300;700;300" dur="9s" repeatCount="indefinite" />
                <animate attributeName="y" values="700;600;700" dur="8s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="60;90;60" dur="6s" repeatCount="indefinite" />
            </text>
            
            <!-- 🎃 -->
            <text x="700" y="300" font-size="70" fill="#fff">
                🎃
                <animate attributeName="x" values="700;600;800;700" dur="7s" repeatCount="indefinite" />
                <animate attributeName="y" values="300;250;350;300" dur="6s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="70;90;70" dur="8s" repeatCount="indefinite" />
            </text>
            
            <!-- 🦄 -->
            <text x="200" y="400" font-size="60" fill="#fff">
                🦄
                <animate attributeName="x" values="200;300;200" dur="5s" repeatCount="indefinite" />
                <animate attributeName="y" values="400;450;400" dur="4s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="60;80;60" dur="7s" repeatCount="indefinite" />
            </text>
            
            <!-- 👽 -->
            <text x="800" y="700" font-size="70" fill="#fff">
                👽
                <animate attributeName="x" values="800;700;900;800" dur="8s" repeatCount="indefinite" />
                <animate attributeName="y" values="700;650;750;700" dur="7s" repeatCount="indefinite" />
                <animate attributeName="font-size" values="70;100;70" dur="9s" repeatCount="indefinite" />
            </text>
            
            <!-- Animated Paths -->
            <path d="M100,500 Q500,100 900,500 Q500,900 100,500" fill="none" stroke="#fff" stroke-width="2">
                <animate attributeName="d" values="
                    M100,500 Q500,100 900,500 Q500,900 100,500;
                    M100,300 Q300,500 500,300 Q700,500 900,300 Q700,700 500,900 Q300,700 100,900 Q300,500 100,300;
                    M100,500 Q500,100 900,500 Q500,900 100,500
                " dur="15s" repeatCount="indefinite" />
                <animate attributeName="stroke" values="#fff;#ff00ff;#00ffff;#fff" dur="10s" repeatCount="indefinite" />
                <animate attributeName="stroke-width" values="2;5;2" dur="5s" repeatCount="indefinite" />
            </path>
            
            <!-- Additional Abstract Elements -->
            <circle cx="200" cy="200" r="50" fill="#ff00ff" opacity="0.5">
                <animate attributeName="cx" values="200;800;200" dur="12s" repeatCount="indefinite" />
                <animate attributeName="cy" values="200;800;200" dur="10s" repeatCount="indefinite" />
                <animate attributeName="r" values="50;100;50" dur="8s" repeatCount="indefinite" />
                <animate attributeName="opacity" values="0.5;0.8;0.5" dur="5s" repeatCount="indefinite" />
            </circle>
            
            <circle cx="800" cy="800" r="70" fill="#00ffff" opacity="0.5">
                <animate attributeName="cx" values="800;200;800" dur="10s" repeatCount="indefinite" />
                <animate attributeName="cy" values="800;200;800" dur="12s" repeatCount="indefinite" />
                <animate attributeName="r" values="70;120;70" dur="9s" repeatCount="indefinite" />
                <animate attributeName="opacity" values="0.5;0.7;0.5" dur="6s" repeatCount="indefinite" />
            </circle>
        </svg>
        
        <!-- Music Player -->
        <audio src="https://music.163.com/song/media/outer/url?id=3346636615.mp3" autoplay loop controls>
            Your browser does not support the audio element.
        </audio>
        
        <!-- Overlay for better visual effect -->
        <div class="overlay"></div>
    </div>
</body>
</html>
