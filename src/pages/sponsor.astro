---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import Giscus from "../components/Giscus.astro";
---
<MainGridLayout title="赞助支持" description="感谢您的支持与鼓励">
  <div class="w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32 mb-6">
    <div class="card-base z-10 px-9 py-16 relative w-full text-center">
      <div class="text-xl font-medium text-neutral-600 dark:text-neutral-400 mb-4">赞助通道维护中</div>
      <a href="https://www.ifdian.net/a/LinmingXHL" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--primary)] hover:underline opacity-70 hover:opacity-100 transition-opacity">我还是想赞助</a>
    </div>
  </div>

  <Giscus class="mt-6"></Giscus>
</MainGridLayout>
