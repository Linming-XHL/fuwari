---
const adTitle = "广告";
const adDescription = "广告位招租";
const qqNumber = "1942239847";
---
<div class="card-base p-2">
    <div class="text-xs text-neutral-400 mb-1.5 flex items-center justify-between">
        <span>{adTitle}</span>
        <span class="text-[11px]">AD</span>
    </div>
    <button onclick={`alert('请联系QQ: ${qqNumber} 洽谈广告合作')`} class="block w-full rounded-lg overflow-hidden group active:scale-95 transition-transform cursor-pointer">
        <div class="bg-gradient-to-r from-[rgb(255,222,255)] to-[rgb(224,255,217)] dark:from-[rgb(100,80,100)] dark:to-[rgb(80,100,75)] p-2 rounded-lg flex items-center justify-center">
            <svg width="100%" height="32" viewBox="0 0 200 32" class="transition-transform duration-300 group-hover:scale-105">
                <text x="100" y="20" font-size="13" font-weight="bold" text-anchor="middle" fill="currentColor">
                    {adDescription}
                </text>
            </svg>
        </div>
    </button>
</div>
